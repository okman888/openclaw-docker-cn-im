# ==========================================
# OpenClaw Docker 精简版最小配置 (基于 init.sh 逻辑)
# ==========================================

# 1. 核心镜像与数据目录
OPENCLAW_IMAGE=justlikemaki/openclaw-docker-cn-im:latest
# 宿主机数据存放目录
OPENCLAW_DATA_DIR=~/.openclaw
# 容器内工作空间根目录 (保持与 init.sh 默认一致)
OPENCLAW_WORKSPACE_ROOT=/home/node/.openclaw

# 2. 自动化同步开关 (确保环境变量生效)
SYNC_OPENCLAW_CONFIG=true
SYNC_MODEL_CONFIG=true
SYNC_EXTENSIONS_ON_START=true

# 3. 模型配置 (同步到 openclaw.json 的 default 提供商)
MODEL_ID=gpt-4o
BASE_URL=https://api.openai.com/v1
API_KEY=sk-your-key-here
API_PROTOCOL=openai-completions
CONTEXT_WINDOW=128000
MAX_TOKENS=4096

# 4. 网关认证 (Web 控制台登录 Token)
OPENCLAW_GATEWAY_TOKEN=123456

# 5. 常用渠道 (按需取消注释并填写，init.sh 会自动处理插件安装)
# TELEGRAM_BOT_TOKEN=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=
# DINGTALK_CARD_STREAMING_MODE=answer
# WECOM_BOT_ID=
# WECOM_SECRET=
